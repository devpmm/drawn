# LLM configuration
SERVER_LLM_API_KEY=your_openai_key_here
SERVER_LLM_BASE_URL=https://api.openai.com/v1
SERVER_LLM_TYPE=openai
SERVER_LLM_MODEL=gpt-5.4

# Access password — both variables must be set to the same value
ACCESS_PASSWORD=your_password_here
NEXT_PUBLIC_ACCESS_PASSWORD=your_password_here
